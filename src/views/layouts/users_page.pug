doctype html
html(lang='ru')
  head
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')

    link(
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css',
      rel='stylesheet'
    )

  body.min-vh-100.d-flex.flex-column
    nav.navbar.navbar-dark.bg-dark
      .container
        a.navbar-brand(href='/') Пользователи

    main.container.my-4.flex-grow-1
      block content
      block search

    footer.bg-dark.text-white.py-3.mt-auto
      .container
        a.text-white(href='https://github.com/TimurL10/hexlet-fastify') Исходный код
        block content h1= course.title p= course.description