extends ../views/layouts/page.pug

block search
    block search
      .card.mb-4
        .card-body
          form(action='/courses' method='get')
            .mb-3
              label.form-label(for='term') Поиск курса
              input#term.form-control(
                type='search'
                name='term'
                placeholder='Введите название курса'
                value=formData.course_name
              )

            .mb-3
              label.form-label(for='category') Категория
              select#category.form-select(name='category')
                option(value='' selected=formData.category === '') Все категории
                option(value='frontend' selected=formData.category === 'frontend') Frontend
                option(value='backend' selected=formData.category === 'backend') Backend
                option(value='database' selected=formData.category === 'database') Базы данных

            .mb-3
              label.form-label(for='level') Уровень
              select#level.form-select(name='level')
                option(value='' selected=formData.level === '') Любой уровень
                option(value='beginner' selected=formData.level === 'beginner') Начальный
                option(value='middle' selected=formData.level === 'middle') Средний
                option(value='advanced' selected=formData.level === 'advanced') Продвинутый

            button.btn.btn-primary(type='submit') Искать

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Курсы
    a.btn.btn-primary(href='/courses/new') New Course

  each course in courses
    .card.mb-3
      .card-body
        h5.card-title= course.title
          