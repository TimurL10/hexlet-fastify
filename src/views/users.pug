extends ../views/layouts/users_page.pug

block content
  if !visited
    h1 Это сообщение показывается только один раз. Если вы хотите увидеть его снова, сотрите куки
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Пользователи
    a.btn.btn-primary(href=rout.get_rout('newUserPath')) New User

  each user in users
    .card.mb-3
      .card-body
        h5.card-title= user.name

        .d-flex.gap-2
          a.btn.btn-outline-primary.btn-sm(href=rout.get_rout('userPath',user.id)) Смотреть
          a.btn.btn-outline-secondary.btn-sm(href=rout.get_rout('editUserPath',user.id)) Изменить   
          form.m-0(action=rout.get_rout('deleteUserPath', user.id) method='post')
            input(type='hidden' name='_method' value='DELETE')
            button.btn.btn-outline-danger.btn-sm(type='submit') Удалить      

